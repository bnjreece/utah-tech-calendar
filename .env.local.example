# Local dev env. Real values come from 1Password (vault: Development).
# Run with: op run --env-file=.env.local -- bun run dev
#
# For now, .env.local contains raw values. Migrate to op:// refs when convenient:
#
# DATABASE_URL=op://Development/Utah Tech Events Neon/url
# CRON_SECRET=op://Development/Utah Tech Events Cron/secret
# MODERATION_SECRET=op://Development/Utah Tech Events Moderation/secret
# RESEND_API_KEY=op://Development/Resend bnjmn/api_key

DATABASE_URL=postgresql://...neon...
CRON_SECRET=
MODERATION_SECRET=
RESEND_API_KEY=

# Clerk auth (admin only)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# Comma-separated list of emails allowed into /admin. Add a maintainer
# by appending their email here (and in Vercel env), then have them sign
# in via Clerk with that address. Defaults to the owner if unset.
ADMIN_EMAILS=b@bnjmn.org

# Silicon Slopes (Circle.so) headless scrape - user_session_identifier cookie
# from a logged-in browser at siliconslopes.com. Rotate every ~60-90 days.
# Store in 1Password as: op://Development/Circle Silicon Slopes/session_cookie
SILICON_SLOPES_SESSION_COOKIE=
