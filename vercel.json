{
  "functions": {
    "src/app/api/cron/scrape/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/digest/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/health-alerts/route.ts": {
      "memory": 256,
      "maxDuration": 60
    },
    "src/app/api/cron/queue-digest/route.ts": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/health-alerts",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/queue-digest",
      "schedule": "30 13 * * *"
    }
  ]
}
