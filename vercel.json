{
  "functions": {
    "src/app/api/cron/scrape/route.ts": {
      "memory": 512,
      "maxDuration": 300
    },
    "src/app/api/cron/digest/route.ts": {
      "memory": 512,
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 14 * * 1"
    }
  ]
}
